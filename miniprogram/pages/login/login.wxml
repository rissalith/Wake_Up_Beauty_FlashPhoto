<view class="login-page">
  <!-- 背景渐变 -->
  <view class="login-bg"></view>

  <!-- 主容器 -->
  <view class="login-container">
    <!-- 顶部返回按钮 -->
    <view class="login-header">
      <view class="back-btn" bindtap="onClose">
        <image src="/images/icon-back-white.svg" class="back-icon"></image>
      </view>
    </view>

    <!-- Logo 和标题 -->
    <view class="login-logo-section">
      <image src="{{logoUrl}}" class="login-logo-img"></image>
      <view class="login-title-wrapper">
        <text class="login-title">Wake Up Beauty</text>
        <text class="login-title">Flash Photo</text>
      </view>
    </view>

    <!-- 登录内容区 -->
    <view class="login-content">
      <!-- 协议勾选区 -->
      <view class="agreement-section">
        <!-- 隐私政策勾选 -->
        <view class="agreement-item {{privacyChecked ? 'checked' : ''}}" bindtap="togglePrivacyCheck">
          <view class="checkbox {{privacyChecked ? 'checked' : ''}}"></view>
          <view class="agreement-text">
            <text class="agreement-label">{{i18n.agreePrivacy || '我已阅读并同意'}}</text>
            <text class="agreement-link" catchtap="viewPrivacyDetail">{{i18n.privacyPolicy || '隐私政策'}}</text>
          </view>
        </view>

        <!-- 用户协议勾选 -->
        <view class="agreement-item {{termsChecked ? 'checked' : ''}}" bindtap="toggleTermsCheck">
          <view class="checkbox {{termsChecked ? 'checked' : ''}}"></view>
          <view class="agreement-text">
            <text class="agreement-label">{{i18n.agreeTerms || '我已阅读并同意'}}</text>
            <text class="agreement-link" catchtap="viewTermsDetail">{{i18n.userAgreement || '用户协议'}}</text>
          </view>
        </view>
      </view>

      <!-- 微信登录按钮 -->
      <view class="login-button-section">
        <button
          class="wx-login-btn {{loading ? 'loading' : ''}}"
          bindtap="onWxLogin"
          disabled="{{loading || !privacyChecked || !termsChecked}}"
          hover-class="{{loading ? '' : 'btn-hover'}}">
          <text>{{loading ? (loginStep || i18n.logging || '登录中...') : (i18n.wxLogin || 'Login')}}</text>
        </button>

        <!-- 登录步骤提示 -->
        <view class="login-step-hint" wx:if="{{loading && loginStep}}">
          <view class="loading-spinner"></view>
          <text>{{loginStep}}</text>
        </view>
      </view>

      <!-- 底部提示 -->
      <view class="login-footer-tip">
        <text>{{i18n.loginTip || '登录即表示您同意上述协议'}}</text>
      </view>
    </view>
  </view>
</view>
