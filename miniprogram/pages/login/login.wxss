/* 登录页面容器 */
.login-page {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100vh;
  background: linear-gradient(135deg, #d4a574 0%, #e8b686 50%, #f0c9a0 100%);
  background-size: 200% 200%;
  animation: gradientShift 8s ease infinite;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

.login-page::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(212, 165, 116, 0.3) 40%,
    rgba(124, 92, 219, 0.2) 50%,
    rgba(212, 165, 116, 0.3) 60%,
    transparent 70%
  );
  animation: shimmerSweep 8s ease-in-out infinite;
  pointer-events: none;
}

/* 背景渐变 */
.login-bg {
  display: none;
}

@keyframes gradientShift {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

@keyframes shimmerSweep {
  0% {
    transform: translate(-100%, -100%) rotate(45deg);
    opacity: 0;
  }
  25% {
    opacity: 1;
  }
  75% {
    opacity: 1;
  }
  100% {
    transform: translate(100%, 100%) rotate(45deg);
    opacity: 0;
  }
}

@keyframes shimmer {
  0% {
    filter: brightness(1) saturate(1);
  }
  50% {
    filter: brightness(1.25) saturate(1.2);
  }
  100% {
    filter: brightness(1) saturate(1);
  }
}

/* 主容器 */
.login-container {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  height: 100%;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 顶部头部 */
.login-header {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  padding: 32px 20px 16px;
  height: 60px;
}

.back-btn {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transition: background 0.3s ease;
}

.back-btn:active {
  background: rgba(255, 255, 255, 0.3);
}

.back-icon {
  width: 24px;
  height: 24px;
  tint-color: #fff;
}

/* Logo 和标题区 */
.login-logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 20px 30px;
  color: #fff;
}

.login-logo-img {
  width: 100px;
  height: 100px;
  margin-bottom: 20px;
  border-radius: 20px;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0px);
  }
  50% {
    transform: translateY(-10px);
  }
}

.login-title-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.login-title {
  font-size: 28px;
  font-weight: 600;
  letter-spacing: 0.5px;
  animation: fadeInDown 0.8s ease-out;
  line-height: 1.2;
}

.login-subtitle {
  font-size: 14px;
  opacity: 0.9;
  font-weight: 400;
  animation: fadeInUp 0.8s ease-out 0.2s both;
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 登录内容区 */
.login-content {
  display: flex;
  flex-direction: column;
  padding: 20px 20px 0;
  background: transparent;
  flex: 1;
}

/* 协议勾选区 */
.agreement-section {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 32px;
}

.agreement-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.35);
  transition: background 0.2s ease;
}

.agreement-item:active {
  background: rgba(255, 255, 255, 0.5);
}

.agreement-item.checked {
  background: rgba(255, 255, 255, 0.6);
}

/* 复选框 */
.checkbox {
  width: 24px;
  height: 24px;
  min-width: 24px;
  border: 2px solid rgba(255, 255, 255, 0.6);
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.3);
  transition: all 0.2s ease;
}

.checkbox.checked {
  background: #fff;
  border-color: #fff;
  animation: checkboxGlow 2s ease-in-out infinite;
  position: relative;
}

.checkbox.checked::after {
  content: '';
  position: absolute;
  width: 6px;
  height: 10px;
  border: solid #d4a574;
  border-width: 0 2px 2px 0;
  transform: rotate(45deg);
  top: 50%;
  left: 50%;
  margin-top: -6px;
  margin-left: -3px;
}

@keyframes checkboxGlow {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.4);
  }
  50% {
    box-shadow: 0 0 8px 2px rgba(255, 255, 255, 0.3);
  }
}

/* 协议文本 */
.agreement-text {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  flex: 1;
  align-items: center;
  line-height: 1.4;
}

.agreement-label {
  font-size: 14px;
  color: #fff;
  font-weight: 500;
}

.agreement-link {
  font-size: 14px;
  color: #fff;
  font-weight: 700;
  text-decoration: underline;
}

/* 登录按钮区 */
.login-button-section {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 10px;
}

.wx-login-btn {
  width: 100%;
  height: 56px;
  background: #fff;
  color: #d4a574;
  border: none;
  border-radius: 28px;
  font-size: 16px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
  white-space: nowrap;
}

.wx-login-btn::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(212, 165, 116, 0.08) 50%,
    transparent 70%
  );
  animation: shine 3s infinite;
}

@keyframes shine {
  0% {
    transform: translate(-100%, -100%) rotate(45deg);
  }
  100% {
    transform: translate(100%, 100%) rotate(45deg);
  }
}

.wx-login-btn:not([disabled]):active {
  transform: translateY(2px);
  box-shadow: 0 2px 8px rgba(212, 165, 116, 0.3);
}

.wx-login-btn[disabled] {
  opacity: 0.5;
  cursor: not-allowed;
}

.wx-login-btn.loading {
  opacity: 0.8;
}

/* 登录步骤提示 */
.login-step-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 12px;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 8px;
  color: #fff;
  font-size: 13px;
}

.loading-spinner {
  width: 16px;
  height: 16px;
  border: 2px solid #fff;
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 底部提示 */
.login-footer-tip {
  text-align: center;
  font-size: 12px;
  color: #fff;
  padding: 12px 0;
  border-top: 1px solid rgba(255, 255, 255, 0.2);
  margin-top: auto;
}

/* 政策详情页面 */
.policy-detail {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  display: flex;
  flex-direction: column;
  z-index: 10;
  border-radius: 24px 24px 0 0;
  margin-top: 60px;
}

.policy-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px;
  border-bottom: 1px solid #f0f0f0;
  background: #fff;
}

.policy-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
}

.policy-close {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
  transition: background 0.2s ease;
}

.policy-close:active {
  background: #efefef;
}

.policy-content {
  flex: 1;
  padding: 20px;
  overflow-y: auto;
}

.policy-text {
  font-size: 14px;
  line-height: 1.8;
  color: #666;
  white-space: pre-wrap;
  word-break: break-word;
}

.policy-footer {
  padding: 16px 20px;
  border-top: 1px solid #f0f0f0;
  background: #fff;
  padding-bottom: calc(16px + env(safe-area-inset-bottom));
}

.policy-confirm-btn {
  width: 100%;
  height: 48px;
  background: linear-gradient(135deg, #d4a574 0%, #e8b686 100%);
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: 16px;
  font-weight: 600;
  transition: all 0.3s ease;
}

.policy-confirm-btn:active {
  transform: translateY(2px);
  opacity: 0.9;
}

/* 响应式设计 */
@media (max-height: 600px) {
  .login-logo-section {
    padding: 20px 20px 15px;
  }

  .login-logo {
    width: 60px;
    height: 60px;
  }

  .login-title {
    font-size: 24px;
  }

  .login-content {
    padding: 20px 20px 10px;
  }

  .agreement-section {
    margin-bottom: 15px;
  }

  .wx-login-btn {
    height: 48px;
    font-size: 15px;
  }
}
