/* 悬浮进度条组件样式 - 优化版 */

.floating-progress {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 1001;
  transform: translateY(-100%);
  transition: transform 0.3s ease-out;
}

.floating-progress.show {
  transform: translateY(0);
}

.progress-inner {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 20rpx;
  border-radius: 0 0 16rpx 16rpx;
}

/* 图标 */
.progress-icon {
  flex-shrink: 0;
  width: 20rpx;
  height: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.spinner {
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-right-color: transparent;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  opacity: 0.6;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.check-icon {
  width: 20rpx;
  height: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  font-weight: bold;
}

/* 文字 */
.progress-content {
  display: flex;
  flex-direction: column;
  gap: 0;
  min-width: 0;
  flex: 1;
}

.progress-main-text {
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.progress-sub-text {
  font-size: 18rpx;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  opacity: 0.7;
}

.progress-arrow {
  flex-shrink: 0;
  font-size: 20rpx;
  opacity: 0.5;
}

/* Golden 主题 */
.theme-golden .progress-inner {
  background: linear-gradient(135deg, #E8B686 0%, #D4956A 100%);
  box-shadow: 0 2rpx 8rpx rgba(232, 182, 134, 0.3);
}

.theme-golden .progress-main-text,
.theme-golden .progress-sub-text,
.theme-golden .spinner,
.theme-golden .check-icon,
.theme-golden .progress-arrow {
  color: #fff;
}

.theme-golden.completed .progress-inner {
  background: linear-gradient(135deg, #F5D0A9 0%, #E8B686 100%);
}

/* Cream 主题 */
.theme-cream .progress-inner {
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border-left: 4rpx solid #E8B686;
}

.theme-cream .progress-main-text {
  color: #5a3e2b;
}

.theme-cream .progress-sub-text {
  color: #a08060;
}

.theme-cream .spinner {
  color: #E8B686;
}

.theme-cream .check-icon {
  color: #52c41a;
}

.theme-cream .progress-arrow {
  color: #c9a880;
}

.theme-cream.completed .progress-inner {
  border-left-color: #52c41a;
}

/* Grey 主题 */
.theme-grey .progress-inner {
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  border-bottom: 3rpx solid #ff6b35;
  border-radius: 0;
}

.theme-grey .progress-main-text {
  color: #333;
}

.theme-grey .progress-sub-text {
  color: #999;
}

.theme-grey .spinner {
  color: #ff6b35;
}

.theme-grey .check-icon {
  color: #52c41a;
}

.theme-grey .progress-arrow {
  color: #ccc;
}

.theme-grey.completed .progress-inner {
  border-bottom-color: #52c41a;
}
